# Environment — copy to .env and fill in values before running

NODE_ENV=development
PORT=3000

# PostgreSQL (Docker Compose service: db)
DATABASE_URL=postgresql://todo_app:changeme@localhost:5432/todo
DATABASE_URL_TEST=postgresql://todo_app:changeme@localhost:5432/todo_test
POSTGRES_PASSWORD=changeme

# Redis (Docker Compose service: redis)
REDIS_URL=redis://localhost:6379

# JWT — minimum 32 characters, use a random secret in production
JWT_SECRET=replace-with-at-least-32-character-random-string
JWT_EXPIRES_IN=15m
JWT_ISSUER=todo-api
JWT_AUDIENCE=todo-client

# CORS — wildcard for development; set to frontend origin in production
CORS_ORIGIN=*

# Logging — trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Security
BCRYPT_ROUNDS=12
